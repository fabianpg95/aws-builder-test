# AWS Region
AWS_REGION=us-east-1

# Cognito
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_APP_CLIENT_ID=XXXXXXXXXXXXXXXXXXXX

# S3 Bucket
S3_BUCKET=smart-uploader-bucket

# DynamoDB Table
DYNAMODB_TABLE=SmartUploaderMetadata

# SNS Topic ARN
SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:SmartUploaderTopic

# SQS Queue URL
SQS_QUEUE_URL=https://sqs.us-east-1.amazonaws.com/123456789012/SmartUploaderQueue

# (Optional) Secrets Manager ARN or Parameter Store path
SECRETS_MANAGER_ARN=arn:aws:secretsmanager:us-east-1:123456789012:secret:yoursecret

# Lambda environment variables can be set in CloudFormation
